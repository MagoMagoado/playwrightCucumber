{
  "name": "automation-pw",
  "version": "1.0.0",
  "description": "Automated tests - Playwright",
  "main": "index.js",
  "scripts": {
    "test": "npx bddgen && npx playwright test",
    "test:local": "npx bddgen && npx playwright test",
    "test:headed": "npx bddgen && npx playwright test --headed",
    "test:debug": "npx bddgen && npx playwright test --debug",
    "test:ui": "npx bddgen && npx playwright test --ui",
    "report": "npx playwright show-report",
    "clean": "rimraf test-results playwright-report .features-gen",
    "pretest": "npm run clean",
    "type-check": "npx tsc --noEmit",
    "lint": "npm run type-check",
    "audit-check": "npm audit --audit-level moderate",
    "setup": "npm install && npx playwright install && npm run type-check",
    "dev": "npm run clean && npm run test:headed"
  },
  "keywords": [
    "playwright",
    "typescript",
    "playwright-bdd",
    "bdd",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@reportportal/agent-js-playwright": "^5.3.2",
    "@types/node": "^20.19.24",
    "@types/oracledb": "^6.5.1",
    "cross-env": "^10.1.0",
    "playwright-bdd": "^8.4.1",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
  },
  "overrides": {
    "glob": "^10.4.0",
    "uuid": "^9.0.1",
    "reflect-metadata": "^0.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
