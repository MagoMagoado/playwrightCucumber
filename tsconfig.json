{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2020", "dom"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@pages/*":    ["src/pages/*"],
      "@steps/*":    ["src/steps/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@elements/*": ["src/elements/*"],
      "@config/*":   ["src/config/*"]
    }
  },
  "include": ["src/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist", ".features-gen"]
}
